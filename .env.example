APP_ENV=development
API_TOKEN=dev-token

# Real provider mode
USE_MOCK_CONNECTORS=false
OPENALEX_BASE_URL=https://api.openalex.org
USE_SEMANTIC_SCHOLAR=true
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
BRAVE_BASE_URL=https://api.search.brave.com

# Provider API keys (set real values)
SEMANTIC_SCHOLAR_API_KEY=
BRAVE_API_KEY=

# Optional AI filter
USE_AI_FILTER=false
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1

# Runtime
ARTIFACTS_DIR=./artifacts
DATABASE_URL=sqlite:///./knowledge_miner.db
LOG_DIR=./logs
LOG_FILE=knowledge_miner.log
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
RUNTIME_STATE_DIR=./runtime
CLEAN_ON_STARTUP=true
